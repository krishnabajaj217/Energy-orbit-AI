<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Outer energy ring -->
    <path
        android:pathData="M 54,24 A 30,30 0 1,1 53.99,24 Z"
        android:strokeWidth="1.5"
        android:strokeColor="#30D5C8"
        android:fillColor="#00000000"/>

    <!-- Diagonal orbiting plasma ring -->
    <path
        android:pathData="M 28,40 Q 54,18 80,40 Q 54,62 28,40"
        android:strokeWidth="2.5"
        android:strokeColor="#FF30D5C8"
        android:fillColor="#00000000"/>

    <!-- Central Glowing Core -->
    <path
        android:pathData="M 54,39 A 15,15 0 1,1 53.99,39 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="15">
                <item android:color="#FFFFFF" android:offset="0.0"/>
                <item android:color="#30D5C8" android:offset="0.6"/>
                <item android:color="#0030D5C8" android:offset="1.0"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Star sparks -->
    <path
        android:pathData="M54,28 L55,33 L60,34 L55,35 L54,40 L53,35 L48,34 L53,33 Z"
        android:fillColor="#FFFFFF"/>
    <path
        android:pathData="M38,50 L39,52 L41,53 L39,54 L38,56 L37,54 L35,53 L37,52 Z"
        android:fillColor="#007AFF"/>
    <path
        android:pathData="M70,58 L71,60 L73,61 L71,62 L70,64 L69,62 L67,61 L69,60 Z"
        android:fillColor="#FFD700"/>
</vector>
